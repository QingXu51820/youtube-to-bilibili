# ── B站 登录凭据（自动扫码，无需手动填写） ──────────────────
# 首次运行 python main.py 时，终端会弹出二维码，
# 用 Bilibili App 扫码即可自动保存凭据到这里。
# 如需手动填写，获取方法: 登录B站 → F12 → Application → Cookies
BILI_SESSDATA=
BILI_BILI_JCT=
# BILI_BUVID3=  # 可选

# ── 翻译设置 ─────────────────────────────────────────────────
# google = Google 翻译（免费，无需 API Key）
# deepseek = DeepSeek API（推荐，需 API Key）
# openai = OpenAI API 或 OpenAI 兼容端点
TRANSLATE_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled
TRANSLATION_PRESERVE_TERMS=Marvel SNAP,SNAP
# 可选：追加自己的标题翻译要求
# TRANSLATION_EXTRA_PROMPT=游戏术语优先保留英文，标题要自然适合B站观众
# 可选：单独指定翻译代理。留空时复用 YOUTUBE_PROXY。
# TRANSLATION_PROXY=http://127.0.0.1:7897
# 如果使用 OpenAI:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# ── 上传设置 ─────────────────────────────────────────────────
# 默认分区: 172 = 游戏-手机游戏
# 游戏常用分区: 17 = 单机游戏, 65 = 网络游戏, 171 = 电子竞技, 172 = 手机游戏, 173 = 桌游棋牌
DEFAULT_TID=172
# 默认标签（逗号分隔）
DEFAULT_TAGS=转载,YouTube

# ── 下载设置 ─────────────────────────────────────────────────
DOWNLOAD_DIR=./downloads
CLEANUP_AFTER_UPLOAD=true
MAX_HEIGHT=1080
DOWNLOAD_MIN_SPEED_KIB=100
DOWNLOAD_SLOW_SECONDS=60
DOWNLOAD_SLOW_GRACE_SECONDS=30
DOWNLOAD_MAX_RESTARTS=3
DOWNLOAD_STARTUP_STATUS_SECONDS=30
# SOURCE_LANG=auto  # 仅对 Google 翻译有效，OpenAI/DeepSeek 自动识别源语言

# ── 字幕设置 ─────────────────────────────────────────────────
# 是否启用字幕下载+翻译+上传功能
SUBTITLE_ENABLED=true
# 字幕处理失败是否导致整个流水线失败（默认 false=非致命）
SUBTITLE_REQUIRED=false
# 匹配 YouTube 字幕语言的 regex pattern，逗号分隔（手动字幕优先，无匹配时 fallback 自动字幕）
SUBTITLE_SOURCE_LANGS=en.*,ja,ko
# 翻译目标语言
SUBTITLE_TARGET_LANG=zh-CN
# 每批翻译的字幕条数
SUBTITLE_TRANSLATE_BATCH_SIZE=80
# 是否上传字幕到 B站（false 时仅生成本地 zh-CN.srt）
SUBTITLE_UPLOAD_TO_BILIBILI=true
# B站字幕语言代码
SUBTITLE_LAN=zh-CN
# B站字幕语言显示名
SUBTITLE_LAN_DOC=中文（简体）
# CID 等待超时（秒）
SUBTITLE_WAIT_CID_SECONDS=300
# CID 轮询间隔（秒）
SUBTITLE_WAIT_CID_INTERVAL=10

# ── 封面设置 ─────────────────────────────────────────────────
COVER_WIDTH=1920
COVER_HEIGHT=1080
COVER_FIT=crop  # crop=居中裁剪, contain=等比缩放加黑边

# ── 运行记录 ─────────────────────────────────────────────────
RUNS_DIR=./runs

# ── YouTube 订阅更新脚本 ─────────────────────────────────────
YOUTUBE_CLIENT_SECRET_FILE=config/client_secret.json
YOUTUBE_TOKEN_FILE=config/youtube_token.json
YOUTUBE_MAX_VIDEOS_PER_CHANNEL=5
YOUTUBE_OUTPUT_FORMAT=table
YOUTUBE_SUBSCRIPTIONS_CACHE=config/subscriptions_cache.json
# 可选：显式指定 Google API 请求代理。留空时读取系统/环境 HTTP_PROXY/HTTPS_PROXY。
# YOUTUBE_PROXY=http://127.0.0.1:7897
# 可选：单独指定下载代理。留空时复用 YOUTUBE_PROXY。
# DOWNLOAD_PROXY=http://127.0.0.1:7897
# 视频分割阈值（秒），超过则分P上传（B站限制10小时）
# MAX_VIDEO_DURATION_SECONDS=36000
# 永久跳过超过该时长的视频（分钟），0=禁用
# YOUTUBE_SKIP_LONG_VIDEO_MINUTES=0
# 自动跳过竖屏视频（YouTube Shorts 等 height > width），默认开启
# YOUTUBE_SKIP_VERTICAL_VIDEOS=true
# ── 内容筛选（用 DeepSeek 判断视频是否与关键词相关）──────
# CONTENT_FILTER_ENABLED=false
# CONTENT_FILTER_KEYWORDS=Marvel SNAP
YOUTUBE_HTTP_TIMEOUT=60
# 读取浏览器 YouTube 登录 Cookie。按顺序尝试；none 表示不读浏览器 Cookie。
# 如需指定浏览器个人资料，可写 chrome:Profile 1 或 firefox:你的配置名。
YOUTUBE_COOKIES_FROM_BROWSER=chrome,edge,firefox
# 自动生成/使用的 Netscape cookies.txt，比每次读取浏览器数据库更稳定。
YOUTUBE_COOKIE_FILE=config/cookies.txt
# YouTube JS challenge 解算组件；用于避免只拿到 storyboard、拿不到视频流。
YTDLP_REMOTE_COMPONENTS=ejs:github

# ── YouTube 订阅自动轮询上传 ─────────────────────────────────────────
YOUTUBE_MONITOR_INTERVAL_SECONDS=3600
YOUTUBE_MONITOR_SOURCE=api
YOUTUBE_MONITOR_LIMIT=50
YOUTUBE_MONITOR_STATE=state/processed_videos.json
# 直播回放或时长达到该分钟数的视频会排到队尾；设为 0 可关闭
YOUTUBE_DEFER_LONG_VIDEO_MINUTES=60
# 网络重试配置
# YOUTUBE_API_MAX_RETRIES=3
# YOUTUBE_API_RETRY_DELAY=2
# YOUTUBE_MONITOR_MAX_RETRIES=5
# YOUTUBE_MONITOR_RETRY_DELAY=30
# YOUTUBE_VIDEO_RETRY_MAX=2
# YOUTUBE_VIDEO_RETRY_DELAY=30

# ── Discord 消息搬运到 B站动态 ───────────────────────────────────────
# 在 Discord Developer Portal (https://discord.com/developers/applications)
# 创建一个 Bot，获取 Token，并将 Bot 邀请到你的服务器。
# 需要的 Bot Intent: MESSAGE CONTENT INTENT (特权), Server Message Intent
DISCORD_BOT_TOKEN=
# 要监听的频道 ID，逗号分隔（在 Discord 中右键频道 → 复制ID）
DISCORD_CHANNEL_IDS=
# 跳过其他 Bot 的消息（默认 true）
DISCORD_SKIP_BOTS=true
# 跳过纯文本无附件的消息（默认 true）
DISCORD_SKIP_EMPTY=true
# 每条动态最多上传几张图片（B站限制最多9张）
DISCORD_MAX_IMAGES=9
# 是否翻译消息文本为中文（默认 true）
DISCORD_TRANSLATE=true
# 状态文件（记录已处理的消息ID，避免重复发布）
DISCORD_STATE_FILE=state/discord_messages.json
# 启动时每条频道回溯获取最近多少条历史消息（补漏）
DISCORD_FALLBACK_LIMIT=20
# Discord 代理（留空则复用 YOUTUBE_PROXY）
# DISCORD_PROXY=http://127.0.0.1:7897

# ── Marvel SNAP 术语表（翻译保护） ─────────────────────────────────
# 自动从 untapped.gg 拉取中英文卡牌/地形名映射，确保翻译时使用官方中文名
SNAP_GLOSSARY_ENABLED=true
# 本地缓存文件（首次运行自动生成）
SNAP_GLOSSARY_CACHE=data/snap_glossary.json
# 刷新间隔（秒），86400=每天检查一次更新
SNAP_GLOSSARY_TTL=86400
